{
	"servers": {
		"io.github.getsentry/sentry-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@sentry/mcp-server@0.25.0"
			],
			"env": {
				"SENTRY_ACCESS_TOKEN": "${input:SENTRY_ACCESS_TOKEN}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.25.0"
		},
		"shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "stitch": {
      "url": "https://stitch.googleapis.com/mcp",
      "type": "http",
      "headers": {
        "Accept": "application/json",
        "X-Goog-Api-Key": "${input:STITCH_API_KEY}"
      }
    }

	},
	"inputs": [
		{
			"id": "SENTRY_ACCESS_TOKEN",
			"type": "promptString",
			"description": "Your Sentry user authentication token",
			"password": true
		},
		{
			"id": "STITCH_API_KEY",
			"type": "promptString",
			"description": "Your Google Cloud API key for Stitch",
			"password": true
		}
	]
}